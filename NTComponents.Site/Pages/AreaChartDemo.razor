@page "/area-chart"
@using NTComponents.Charts
@using NTComponents.Charts.Core
@using NTComponents.Charts.Core.Axes

<div class="p-4">
   <h3>Area Chart Demo</h3>

   <div style="height: 500px; width: 100%;" class="mt-4 border rounded p-2">
      <NTChart TData="DataItem" Title="Revenue vs Costs Over Time" RangePadding="0.05">
         <NTCartesianAxis TData="DataItem" Direction="AxisDirection.X" Title="Month" />
         <NTCartesianAxis TData="DataItem" Direction="AxisDirection.Y" Title="Value ($)" />

         <NTAreaSeries TData="DataItem" Data="@Data" XValueSelector="@(d => d.Id)" YValueSelector="@(d => d.Revenue)"
            Title="Revenue" Color="TnTColor.Primary" AreaOpacity="0.3f" />

         <NTAreaSeries TData="DataItem" Data="@Data" XValueSelector="@(d => d.Id)" YValueSelector="@(d => d.Costs)"
            Title="Costs" Color="TnTColor.Error" AreaOpacity="0.3f" />
      </NTChart>
   </div>
</div>

@code {
   public class DataItem
   {
      public int Id { get; set; }
      public string Month { get; set; } = string.Empty;
      public double Revenue { get; set; }
      public double Costs { get; set; }
   }

   private List<DataItem> Data = new()
{
new DataItem { Id = 1, Month = "Jan", Revenue = 4000, Costs = 2400 },
new DataItem { Id = 2, Month = "Feb", Revenue = 3000, Costs = 1398 },
new DataItem { Id = 3, Month = "Mar", Revenue = 2000, Costs = 9800 },
new DataItem { Id = 4, Month = "Apr", Revenue = 2780, Costs = 3908 },
new DataItem { Id = 5, Month = "May", Revenue = 1890, Costs = 4800 },
new DataItem { Id = 6, Month = "Jun", Revenue = 2390, Costs = 3800 },
new DataItem { Id = 7, Month = "Jul", Revenue = 3490, Costs = 4300 },
};
}